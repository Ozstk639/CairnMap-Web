{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cairnmap.local/schemas/cairnmap.search-profiles.v1.schema.json",
  "title": "CairnMap Search Profiles",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "const": "cairnmap.search-profiles.v1"
    },
    "projectId": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "defaultProfileId": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "searchFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blacklist": {
            "type": "array"
          },
          "priority": {
            "type": "array"
          },
          "categoryOverrides": {
            "type": "array"
          }
        }
      }
    }
  },
  "required": [
    "schemaVersion",
    "items"
  ]
}
