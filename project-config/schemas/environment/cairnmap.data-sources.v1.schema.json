{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cairnmap.local/schemas/cairnmap.data-sources.v1.schema.json",
  "title": "CairnMap Data Sources",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "const": "cairnmap.data-sources.v1"
    },
    "projectId": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "worldId": {
            "type": "string"
          },
          "baseUrl": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sourceMode": {
            "type": "string"
          },
          "pictureSourceMode": {
            "type": "string"
          }
        },
        "required": [
          "worldId"
        ]
      }
    }
  },
  "required": [
    "schemaVersion",
    "items"
  ]
}
