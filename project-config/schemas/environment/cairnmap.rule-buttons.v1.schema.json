{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cairnmap.local/schemas/cairnmap.rule-buttons.v1.schema.json",
  "title": "CairnMap Rule Buttons",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "const": "cairnmap.rule-buttons.v1"
    },
    "projectId": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "storageKey": {
      "type": "string"
    },
    "legacyStorageKeys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": true
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            ]
          },
          "tone": {
            "type": "string"
          },
          "iconKey": {
            "type": "string"
          },
          "defaultEnabled": {
            "type": "boolean"
          },
          "criteria": {
            "type": "object",
            "additionalProperties": true
          },
          "behavior": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "required": [
    "schemaVersion",
    "items"
  ]
}
