{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cairnmap.local/schemas/cairnmap.worlds.v1.schema.json",
  "title": "CairnMap Worlds",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "const": "cairnmap.worlds.v1"
    },
    "projectId": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "numericCode": {
            "type": "number"
          },
          "label": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            ]
          },
          "enabled": {
            "type": "boolean"
          },
          "default": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "label"
        ]
      }
    }
  },
  "required": [
    "schemaVersion",
    "items"
  ]
}
