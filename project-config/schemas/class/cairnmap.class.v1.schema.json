{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cairnmap.local/schemas/cairnmap.class.v1.schema.json",
  "title": "CairnMap Class",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "const": "cairnmap.class.v1"
    },
    "projectId": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "runtimeStatus": {
      "enum": [
        "active"
      ]
    },
    "classCode": {
      "type": "string"
    },
    "classKey": {
      "type": "string"
    },
    "sourceFeatureKey": {
      "type": "string"
    },
    "label": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      ]
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    },
    "geometry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "sourceField": {
          "type": "string"
        },
        "axisOrder": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": true
    },
    "classification": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "options": {
          "type": "array"
        }
      }
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "key",
          "label",
          "type"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "label": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            ]
          },
          "type": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "optional": {
            "type": "boolean"
          },
          "sourceRuntimeField": {
            "type": "string"
          },
          "scenes": {
            "type": "object",
            "additionalProperties": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "tags": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "display": {
      "type": "object",
      "additionalProperties": true
    },
    "card": {
      "type": "object",
      "additionalProperties": true
    },
    "workflowBindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "required": [
    "schemaVersion",
    "runtimeStatus",
    "classCode",
    "classKey",
    "label",
    "geometry",
    "identity",
    "fields"
  ]
}
