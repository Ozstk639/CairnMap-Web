{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cairnmap.local/schemas/cairnmap.workflow.v1.schema.json",
  "title": "CairnMap Workflow",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "const": "cairnmap.workflow.v1"
    },
    "projectId": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "label": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      ]
    },
    "runtimeStatus": {
      "enum": [
        "active"
      ]
    },
    "targetClass": {
      "type": "string"
    },
    "targetGeometry": {
      "type": "string"
    },
    "runtimeMode": {
      "const": "componentExecutor"
    },
    "componentKey": {
      "type": "string"
    },
    "legacyWorkflowKey": {
      "type": "string"
    },
    "blockRunnerReady": {
      "const": false
    },
    "futureBlockTemplateRef": {
      "type": "string"
    },
    "executorDispatch": {
      "type": "string"
    },
    "legacyFallback": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "runtimeStatus",
    "targetClass",
    "runtimeMode",
    "componentKey",
    "blockRunnerReady"
  ]
}
