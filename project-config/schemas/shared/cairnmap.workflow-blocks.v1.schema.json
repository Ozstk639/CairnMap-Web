{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cairnmap.local/schemas/cairnmap.workflow-blocks.v1.schema.json",
  "title": "CairnMap Workflow Blocks",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "const": "cairnmap.workflow-blocks.v1"
    },
    "projectId": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "workflowKey": {
            "type": "string"
          },
          "componentKey": {
            "type": "string"
          },
          "label": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            ]
          },
          "runtimeStatus": {
            "type": "string"
          }
        },
        "required": []
      }
    }
  },
  "required": [
    "schemaVersion",
    "items"
  ]
}
